# OpenAI API key for embeddings, grading, and generation
OPENAI_API_KEY=sk-your-openai-api-key

# Qdrant Cloud connection — always include :6333; without it you often get HTTP 404.
QDRANT_URL=https://your-cluster.cloud.qdrant.io:6333
QDRANT_API_KEY=your-qdrant-api-key

# Qdrant collection name (default: crag_docs)
COLLECTION_NAME=crag_docs

# Tavily API key for web search fallback
TAVILY_API_KEY=tvly-your-tavily-api-key

# Langfuse observability keys
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# Retrieval settings
TOP_K=5
MAX_REWRITE_ITERATIONS=2

# Ingestion (chunking for /documents/upload and /documents/text)
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MAX_UPLOAD_BYTES=15728640

# Model selection
GRADER_MODEL=gpt-4o-mini
GENERATOR_MODEL=gpt-4o
